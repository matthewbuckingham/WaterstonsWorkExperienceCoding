---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "About Me";
const identity = {
    firstName:
    "Matthew",
    country: "England",
    occupation: "Student",
    hobbies: "Video Gaming, Badminton and Coding"
};
const skills = ["Python", "JavaScript", "Astro", "C++"]
const happy = true;
const finished = false;
const goal = 3;
---
<BaseLayout pageTitle={pageTitle}>
    <h2>My awesome blog subtitle</h2>
</BaseLayout>

        <ul>
            <li>My name is {identity.firstName}, I'm from {identity.country} and I'm a {identity.occupation}.</li>
            <li>My hobbies include {identity.hobbies}.</li>
            <li>I have experience with the following skills: <span class="skill">{skills[0]}</span>, <span class="skill">{skills[1]}</span>, <span class="skill">{skills[2]}</span> and <span class="skill">{skills[3]}</span>.</li>
            <li> {happy &&  <p>I'm happy to be using Astro!</p>} </li>
            <li> {finished === false ? <p>I'm not finished yet!</p> : <p>I'm finished.</p>} </li>
            <li> {goal === 3 ? <p>My goal is to finish before my Work Experience ends.</p> : <p> My goal isn't to finish but to do as much as I can.</p>}</li>
        </ul>

        <p>I'm currently at Waterstons on Work Experience, and I've met some really nice people!</p>
        <p>Currently, I'm updating the website live, so keep having a look when you get a chance...</p>

        <p></p>
        <Footer />
	</body>
</html>

